\BKM@entry{id=5,dest={73656374696F6E2E36},srcline={63}}{5C3337365C3337375C303030535C303030705C303030655C303030655C303030645C3030302D5C303030755C303030705C3030305C3034305C303030415C3030306E5C303030615C3030306C5C303030795C303030735C303030695C30303073}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Mean runtime versus patch size for $c = c_s$, $size = 900$, $p = 20$, fine sweep over $\text  {patch} \in [20, 60]$. The empirical analysis suggests that the ideal patch size is 27. However, the data seems quite noisy. Furthermore, the difference in the mean runtime is not significant.}}{8}{figure.8}\protected@file@percent }
\newlabel{fig:patch-optimal}{{8}{8}{Mean runtime versus patch size for $c = c_s$, $size = 900$, $p = 20$, fine sweep over $\text {patch} \in [20, 60]$. The empirical analysis suggests that the ideal patch size is 27. However, the data seems quite noisy. Furthermore, the difference in the mean runtime is not significant}{figure.8}{}}
