#!/bin/bash
#SBATCH -p q_student
#SBATCH -N 1
#SBATCH -c 32
#SBATCH -t 5
#SBATCH -o bench_optimal_%j.out

SCRIPT="bopc/julia_set/julia_par.py"
SIZE=900
NPROCS=20
REPS=3
CSV="results_optimal_${SLURM_JOB_ID}.csv"

echo "size,patch,nprocs,runtime,rep" > "$CSV"

for patch in $(seq 20 60); do
    for rep in $(seq 1 $REPS); do
        OUT=$(python3 "$SCRIPT" --size "$SIZE" --patch "$patch" --nprocs "$NPROCS")
        echo "${OUT//;/,},${rep}" >> "$CSV"
    done
done

echo "Done. Wrote $CSV"
