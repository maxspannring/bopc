\@writefile{toc}{\contentsline {section}{\numberline {4}Influence of patch size}{6}{section.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Mean runtime as a function of patch size, with $size = 880$ and $p = 32$, three repetitions per configuration.}}{6}{table.3}\protected@file@percent }
\newlabel{tab:patch_influence}{{3}{6}{Mean runtime as a function of patch size, with $size = 880$ and $p = 32$, three repetitions per configuration}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Mean runtime versus patch size for $c = c_s$, $size = 880$, $p = 32$. As we can see, the mean runtime drops significantly for patch sizes that are only a litle bit larger than 1. This is because very small patch sizes lead to large overhead. However, at the larger end for patch sizes we see an increase in mean runtime. This might be due to load balancing, since some workers finish earlier, because there are not enough patches for a comparatively small image.}}{6}{figure.7}\protected@file@percent }
\newlabel{fig:patch-influence}{{7}{6}{Mean runtime versus patch size for $c = c_s$, $size = 880$, $p = 32$. As we can see, the mean runtime drops significantly for patch sizes that are only a litle bit larger than 1. This is because very small patch sizes lead to large overhead. However, at the larger end for patch sizes we see an increase in mean runtime. This might be due to load balancing, since some workers finish earlier, because there are not enough patches for a comparatively small image}{figure.7}{}}
