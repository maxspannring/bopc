\@writefile{toc}{\contentsline {section}{\numberline {2}Introduction}{1}{section.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3}Compute Speed-up and Parallel Efficiency for 2 Instance Sizes}{1}{section.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Runtime and speed-up of parallel Julia set generator for $c_s$ case.}}{1}{table.1}\protected@file@percent }
\newlabel{tab:runtime_cs}{{1}{1}{Runtime and speed-up of parallel Julia set generator for $c_s$ case}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Runtime and speed-up of parallel Julia set generator for $c_b$ case.}}{2}{table.2}\protected@file@percent }
\newlabel{tab:runtime_cb}{{2}{2}{Runtime and speed-up of parallel Julia set generator for $c_b$ case}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Mean runtime versus number of workers for $c = c_b$. As we can see, the mean runtime for large problem sizes is much larger at the beginning and thus dwarfes the graph for smaller runtimes. We can also implicitly see that the relative speedup is better for larger problem sizes.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:cb-runtime}{{1}{2}{Mean runtime versus number of workers for $c = c_b$. As we can see, the mean runtime for large problem sizes is much larger at the beginning and thus dwarfes the graph for smaller runtimes. We can also implicitly see that the relative speedup is better for larger problem sizes}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Relative speed-up versus number of workers for $c = c_b$. In the ideal case, we would expect a linear scaling $S(p)=p$. However, due to computational overhead, this is not the case. As already mentioned in the caption of figure ~\ref {fig:cb-runtime}, larger problem sizes have a better relative speed up because the overhead costs amortize.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:cb-speedup}{{2}{3}{Relative speed-up versus number of workers for $c = c_b$. In the ideal case, we would expect a linear scaling $S(p)=p$. However, due to computational overhead, this is not the case. As already mentioned in the caption of figure ~\ref {fig:cb-runtime}, larger problem sizes have a better relative speed up because the overhead costs amortize}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Parallel efficiency versus number of workers for $c = c_b$. The paralell efficiency of small problem sizes drops concerningly low very quickly. Large problem sizes are using more cores more efficiently.}}{3}{figure.3}\protected@file@percent }
\newlabel{fig:cb-efficiency}{{3}{3}{Parallel efficiency versus number of workers for $c = c_b$. The paralell efficiency of small problem sizes drops concerningly low very quickly. Large problem sizes are using more cores more efficiently}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Mean runtime versus number of workers for $c = c_s$. Similar to the case of $c = c_b$.}}{4}{figure.4}\protected@file@percent }
\newlabel{fig:cs-runtime}{{4}{4}{Mean runtime versus number of workers for $c = c_s$. Similar to the case of $c = c_b$}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Relative speed-up versus number of workers for $c = c_s$. Similar to the case of $c = c_b$.}}{4}{figure.5}\protected@file@percent }
\newlabel{fig:cs-speedup}{{5}{4}{Relative speed-up versus number of workers for $c = c_s$. Similar to the case of $c = c_b$}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Parallel efficiency versus number of workers for $c = c_s$. Similar to the case of $c = c_b$.}}{5}{figure.6}\protected@file@percent }
\newlabel{fig:cs-efficiency}{{6}{5}{Parallel efficiency versus number of workers for $c = c_s$. Similar to the case of $c = c_b$}{figure.6}{}}
\BKM@entry{id=3,dest={73656374696F6E2E34},srcline={66}}{5C3337365C3337375C303030495C3030306E5C303030665C3030306C5C303030755C303030655C3030306E5C303030635C303030655C3030305C3034305C3030306F5C303030665C3030305C3034305C303030705C303030615C303030745C303030635C303030685C3030305C3034305C303030735C303030695C3030307A5C30303065}
